@page
@model WeightTracker.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Theme"] = Model.Theme;
    var initialDay = Model.CalendarDays.LastOrDefault(day => !day.IsFuture) ?? Model.CalendarDays.FirstOrDefault();
}

<div asp-validation-summary="All" class="validation-summary"></div>
@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="status-message" role="status">@Model.StatusMessage</div>
}

<div class="weight-app">
    <header class="app-header">
        <div>
            <p class="eyebrow">WeightTracker</p>
            <h1>Dashboard</h1>
        </div>
        <span class="app-header__date">@Model.Today.ToString("dd MMM")</span>
    </header>

    <section class="weight-hero" aria-label="Latest weight">
        <div>
            <p class="eyebrow">Latest weight</p>
            <strong class="weight-hero__value">@Model.FormatWeight(Model.Summary.LatestWeightKg)</strong>
        </div>
        <button type="button" class="primary-action" data-open-entry>Add / Update</button>
    </section>

    <section class="goal-panel" aria-label="Goal">
        <div>
            <p class="eyebrow">Goal</p>
            <strong class="goal-panel__value">@(Model.HasGoal ? Model.FormatWeight(Model.Summary.GoalWeightKg) : "No goal set")</strong>
            <span>@Model.FormatGoalPanelDetail()</span>
        </div>
        <button type="button" class="trophy-button" data-open-goal aria-label="@Model.GoalActionLabel">&#127942;</button>
    </section>

    <section class="metric-strip" aria-label="Weight metrics">
        <article>
            <span>7-day avg</span>
            <strong>@Model.FormatWeight(Model.Summary.SevenDayMovingAverageKg)</strong>
        </article>
        <article>
            <span>Week delta</span>
            <strong>@Model.FormatSignedWeight(Model.Summary.WeekOverWeekDeltaKg)</strong>
        </article>
        <article>
            <span>@(Model.Summary.GoalWeightKg.HasValue ? "Goal gap" : "30-day")</span>
            <strong>@Model.FormatGoalDistance()</strong>
        </article>
    </section>

    <section class="trend-panel" aria-label="Weight trend">
        <div class="section-heading trend-heading">
            <div>
                <h2>Trend</h2>
                <span data-trend-range-label>Last 6 months</span>
            </div>
            <div class="trend-range-selector" aria-label="Trend time frame">
                <button type="button" data-trend-range="1m" data-range-label="Last month" aria-pressed="false">1M</button>
                <button type="button" data-trend-range="3m" data-range-label="Last 3 months" aria-pressed="false">3M</button>
                <button type="button" data-trend-range="6m" data-range-label="Last 6 months" aria-pressed="true">6M</button>
                <button type="button" data-trend-range="1y" data-range-label="Last year" aria-pressed="false">1Y</button>
                <button type="button" data-trend-range="all" data-range-label="All entries" aria-pressed="false">All</button>
            </div>
        </div>
        <div class="trend-chart-frame">
            <canvas id="trendChart"></canvas>
        </div>
    </section>

    <section class="history-panel" aria-label="Recent history">
        <div class="section-heading">
            <h2>Recent history</h2>
            <span>@Model.RecentHistory.Count entries</span>
        </div>
        @if (Model.RecentHistory.Count == 0)
        {
            <p class="empty-state">No weights recorded yet.</p>
        }
        else
        {
            <ol class="history-list">
                @foreach (var row in Model.RecentHistory)
                {
                    <li>
                        <span>@Model.FormatHistoryDate(row.EntryDate)</span>
                        <strong>@Model.FormatWeight(row.WeightKg)</strong>
                    </li>
                }
            </ol>
        }
    </section>


    <section class="insights-panel" aria-label="Weight insights">
        <div class="section-heading">
            <h2>Insights</h2>
            <span>All recorded weights</span>
        </div>
        <div class="insight-grid">
            <article>
                <span>Latest</span>
                <strong>@Model.FormatWeight(Model.Summary.LatestWeightKg)</strong>
            </article>
            <article>
                <span>High</span>
                <strong>@Model.FormatWeight(Model.Summary.RangeHighKg)</strong>
            </article>
            <article>
                <span>Low</span>
                <strong>@Model.FormatWeight(Model.Summary.RangeLowKg)</strong>
            </article>
            <article>
                <span>30-day</span>
                <strong>@Model.FormatSignedWeight(Model.Summary.ThirtyDayChangeKg)</strong>
            </article>
            <article>
                <span>90-day</span>
                <strong>@Model.FormatSignedWeight(Model.Summary.NinetyDayChangeKg)</strong>
            </article>
            <article>
                <span>Entry count</span>
                <strong>@Model.EntryCount</strong>
            </article>
        </div>
    </section>
    <section class="data-panel" aria-label="Data management">
        <div class="section-heading">
            <h2>Data</h2>
            <span>Weight entries only</span>
        </div>
        <div class="data-actions">
            <a class="primary-action action-button" asp-page-handler="ExportCsv">Export CSV</a>
            <button type="button" class="primary-action action-button" data-open-import>Import CSV</button>
            <button type="button" class="secondary-action action-button" data-open-delete-all>Delete all</button>
        </div>
    </section>
</div>

<dialog id="entryDialog" class="entry-dialog" role="dialog" aria-modal="true" aria-labelledby="entryDialogTitle">
    <form method="post" class="entry-dialog__form">
        <div class="entry-dialog__header">
            <div>
                <p class="eyebrow">New weight</p>
                <h2 id="entryDialogTitle">@Model.CalendarMonthLabel</h2>
            </div>
            <button type="button" class="icon-button" data-close-entry aria-label="Close">x</button>
        </div>

        <div class="calendar-nav" aria-label="Calendar month navigation">
            <a class="icon-button" href="?month=@Model.PreviousCalendarMonthQuery" aria-label="Previous month">&lt;</a>
            <strong>@Model.CalendarMonthLabel</strong>
            @if (Model.NextCalendarMonthQuery is null)
            {
                <span class="icon-button is-disabled" aria-hidden="true">&gt;</span>
            }
            else
            {
                <a class="icon-button" href="?month=@Model.NextCalendarMonthQuery" aria-label="Next month">&gt;</a>
            }
        </div>

        <div class="entry-calendar" data-entry-calendar>
            <div class="calendar-weekdays" aria-hidden="true">
                <span>Mon</span>
                <span>Tue</span>
                <span>Wed</span>
                <span>Thu</span>
                <span>Fri</span>
                <span>Sat</span>
                <span>Sun</span>
            </div>
            <div class="calendar-grid">
                @for (var blank = 0; blank < Model.CalendarLeadingBlankCount; blank++)
                {
                    <span class="calendar-day calendar-day--blank" aria-hidden="true"></span>
                }
                @foreach (var day in Model.CalendarDays)
                {
                    var isInitialDay = initialDay is not null && day.EntryDate == initialDay.EntryDate;
                    <button type="button"
                            class="calendar-day @(day.IsToday ? "is-today" : null) @(day.HasEntry ? "has-entry" : null) @(isInitialDay ? "is-selected" : null)"
                            data-calendar-day="@Model.EntryDateIso(day.EntryDate)"
                            data-entry-date="@Model.EntryDateIso(day.EntryDate)"
                            data-entry-weight="@Model.InputValue(day)"
                            disabled="@day.IsFuture"
                            aria-pressed="@(isInitialDay ? "true" : "false")">
                        @day.EntryDate.Day
                    </button>
                }
            </div>
        </div>

        <input type="hidden" id="selectedEntryDate" name="EntryDate" value="@(initialDay is null ? Model.EntryDateIso(Model.Today) : Model.EntryDateIso(initialDay.EntryDate))" />

        <label class="weight-input-label" for="weightInput">Weight (@Model.DisplayUnit)</label>
        <input id="weightInput"
               class="weight-input"
               name="Weight"
               value="@(initialDay is null ? Model.InputWeightValue(Model.TodayWeightKg) : Model.InputValue(initialDay))"
               type="text"
               inputmode="decimal"
               autocomplete="off"
               data-decimal-input
               aria-describedby="weight-validation" />
        <span id="weight-validation" asp-validation-for="Weight"></span>

        <div class="entry-dialog__actions">
            <button type="submit" class="primary-action">Save</button>
            <button type="submit"
                    class="secondary-action"
                    asp-page-handler="Delete"
                    data-delete-entry
                    hidden="@(initialDay is null || !initialDay.HasEntry || initialDay.IsToday)"
                    onclick="return confirm('Delete this past entry?');">
                Delete
            </button>
        </div>
    </form>
</dialog>

<dialog id="goalDialog" class="goal-dialog" role="dialog" aria-modal="true" aria-labelledby="goalDialogTitle" data-open-goal-on-load="@Model.GoalDialogOpenAttribute">
    <form method="post" class="entry-dialog__form" asp-page-handler="Goal">
        <div class="entry-dialog__header">
            <div>
                <p class="eyebrow">Goal</p>
                <h2 id="goalDialogTitle">Target weight</h2>
            </div>
            <button type="button" class="icon-button" data-close-goal aria-label="Close">x</button>
        </div>

        <label class="weight-input-label" for="goalWeightInput">Goal weight (@Model.DisplayUnit)</label>
        <input id="goalWeightInput"
               class="weight-input"
               name="GoalWeight"
               value="@Model.GoalInputValue()"
               type="text"
               inputmode="decimal"
               autocomplete="off"
               data-decimal-input
               aria-describedby="goal-validation" />
        <span id="goal-validation" asp-validation-for="GoalWeight"></span>

        <div class="entry-dialog__actions">
            <button type="submit" class="primary-action">Save</button>
            @if (Model.HasGoal)
            {
                <button type="submit" class="secondary-action" asp-page-handler="ClearGoal">Clear goal</button>
            }
            <button type="button" class="secondary-action secondary-action--neutral" data-close-goal>Cancel</button>
        </div>
    </form>
</dialog>

<dialog id="importCsvDialog" class="import-dialog" role="dialog" aria-modal="true" aria-labelledby="importCsvDialogTitle">
    <form method="post" enctype="multipart/form-data" asp-page-handler="ImportCsv" class="entry-dialog__form">
        <div class="entry-dialog__header">
            <div>
                <p class="eyebrow">Import</p>
                <h2 id="importCsvDialogTitle">Import CSV</h2>
            </div>
            <button type="button" class="icon-button" data-close-import aria-label="Close">x</button>
        </div>
        <label class="weight-input-label" for="importFile">CSV file</label>
        <input id="importFile" class="file-input" type="file" name="ImportFile" accept=".csv,text/csv" />
        <div class="entry-dialog__actions">
            <button type="submit" class="primary-action">Import CSV</button>
            <button type="button" class="secondary-action secondary-action--neutral" data-close-import>Cancel</button>
        </div>
    </form>
</dialog>

<dialog id="deleteAllWarningDialog" class="delete-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteAllWarningTitle">
    <div class="entry-dialog__form">
        <div class="entry-dialog__header">
            <div>
                <p class="eyebrow">Delete all</p>
                <h2 id="deleteAllWarningTitle">Delete every weight entry?</h2>
            </div>
            <button type="button" class="icon-button" data-close-delete-all-warning aria-label="Close">x</button>
        </div>
        <p class="dialog-copy">This permanently deletes all recorded weights. Export a CSV first if you need a backup.</p>
        <div class="entry-dialog__actions">
            <button type="button" class="secondary-action" data-continue-delete-all>Continue</button>
            <button type="button" class="secondary-action secondary-action--neutral" data-close-delete-all-warning>Cancel</button>
        </div>
    </div>
</dialog>

<dialog id="deleteAllConfirmDialog" class="delete-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteAllConfirmTitle">
    <form method="post" class="entry-dialog__form" asp-page-handler="DeleteAllWeights">
        <div class="entry-dialog__header">
            <div>
                <p class="eyebrow">Confirm</p>
                <h2 id="deleteAllConfirmTitle">Type DELETE</h2>
            </div>
            <button type="button" class="icon-button" data-close-delete-all-confirm aria-label="Close">x</button>
        </div>
        <p class="dialog-copy">This action cannot be undone. Settings and goals stay unchanged.</p>
        <label class="weight-input-label" for="deleteAllConfirmation">Confirmation</label>
        <input id="deleteAllConfirmation"
               class="text-input"
               name="DeleteAllConfirmation"
               type="text"
               autocomplete="off"
               data-delete-all-confirm-input />
        <div class="entry-dialog__actions">
            <button type="submit" class="secondary-action" data-delete-all-submit disabled>Delete all</button>
            <button type="button" class="secondary-action secondary-action--neutral" data-close-delete-all-confirm>Cancel</button>
        </div>
    </form>
</dialog>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.querySelectorAll('[data-decimal-input]').forEach((input) => {
            input.addEventListener('input', () => {
                const separator = input.value.includes(',') ? ',' : '.';
                let hasSeparator = false;
                input.value = Array.from(input.value)
                    .filter((character) => {
                        if (/\d/.test(character)) {
                            return true;
                        }

                        if ((character === '.' || character === ',') && !hasSeparator) {
                            hasSeparator = true;
                            return true;
                        }

                        return false;
                    })
                    .join('')
                    .replace(separator === ',' ? '.' : ',', separator);
            });
        });

        const today = '@Model.EntryDateIso(Model.Today)';
        const entryDialog = document.getElementById('entryDialog');
        const weightInput = document.getElementById('weightInput');
        const goalDialog = document.getElementById('goalDialog');
        const goalWeightInput = document.getElementById('goalWeightInput');
        const selectedEntryDate = document.getElementById('selectedEntryDate');
        const deleteButton = document.querySelector('[data-delete-entry]');
        const calendarDays = Array.from(document.querySelectorAll('[data-calendar-day]'));
        const importDialog = document.getElementById('importCsvDialog');
        const deleteAllWarningDialog = document.getElementById('deleteAllWarningDialog');
        const deleteAllConfirmDialog = document.getElementById('deleteAllConfirmDialog');
        const deleteAllConfirmInput = document.querySelector('[data-delete-all-confirm-input]');
        const deleteAllSubmit = document.querySelector('[data-delete-all-submit]');

        function selectCalendarDay(dayButton) {
            calendarDays.forEach((button) => {
                button.classList.toggle('is-selected', button === dayButton);
                button.setAttribute('aria-pressed', button === dayButton ? 'true' : 'false');
            });

            selectedEntryDate.value = dayButton.dataset.calendarDay;
            weightInput.value = dayButton.dataset.entryWeight || '';

            if (deleteButton) {
                deleteButton.hidden = !dayButton.dataset.entryWeight || dayButton.dataset.calendarDay >= today;
            }
        }

        calendarDays.forEach((button) => {
            button.addEventListener('click', () => selectCalendarDay(button));
        });

        document.querySelectorAll('[data-open-entry]').forEach((button) => {
            button.addEventListener('click', () => {
                if (entryDialog.showModal) {
                    entryDialog.showModal();
                } else {
                    entryDialog.setAttribute('open', 'open');
                }
                weightInput.focus();
            });
        });

        document.querySelectorAll('[data-close-entry]').forEach((button) => {
            button.addEventListener('click', () => entryDialog.close());
        });

        document.querySelectorAll('[data-open-goal]').forEach((button) => {
            button.addEventListener('click', () => {
                if (goalDialog.showModal) {
                    goalDialog.showModal();
                } else {
                    goalDialog.setAttribute('open', 'open');
                }
                goalWeightInput.focus();
            });
        });

        document.querySelectorAll('[data-close-goal]').forEach((button) => {
            button.addEventListener('click', () => goalDialog.close());
        });

        if (goalDialog && goalDialog.dataset.openGoalOnLoad === 'true') {
            if (goalDialog.showModal) {
                goalDialog.showModal();
            } else {
                goalDialog.setAttribute('open', 'open');
            }
            goalWeightInput.focus();
        }

        function showDialog(dialog) {
            if (!dialog) {
                return;
            }

            if (dialog.showModal) {
                dialog.showModal();
            } else {
                dialog.setAttribute('open', 'open');
            }
        }

        function closeDialog(dialog) {
            if (!dialog) {
                return;
            }

            if (dialog.close) {
                dialog.close();
            } else {
                dialog.removeAttribute('open');
            }
        }

        document.querySelectorAll('[data-open-import]').forEach((button) => {
            button.addEventListener('click', () => showDialog(importDialog));
        });

        document.querySelectorAll('[data-close-import]').forEach((button) => {
            button.addEventListener('click', () => closeDialog(importDialog));
        });

        document.querySelectorAll('[data-open-delete-all]').forEach((button) => {
            button.addEventListener('click', () => showDialog(deleteAllWarningDialog));
        });

        document.querySelectorAll('[data-close-delete-all-warning]').forEach((button) => {
            button.addEventListener('click', () => closeDialog(deleteAllWarningDialog));
        });

        document.querySelectorAll('[data-continue-delete-all]').forEach((button) => {
            button.addEventListener('click', () => {
                closeDialog(deleteAllWarningDialog);
                if (deleteAllConfirmInput) {
                    deleteAllConfirmInput.value = '';
                }
                if (deleteAllSubmit) {
                    deleteAllSubmit.disabled = true;
                }
                showDialog(deleteAllConfirmDialog);
                deleteAllConfirmInput?.focus();
            });
        });

        document.querySelectorAll('[data-close-delete-all-confirm]').forEach((button) => {
            button.addEventListener('click', () => closeDialog(deleteAllConfirmDialog));
        });

        deleteAllConfirmInput?.addEventListener('input', () => {
            if (deleteAllSubmit) {
                deleteAllSubmit.disabled = deleteAllConfirmInput.value !== 'DELETE';
            }
        });
        if (document.querySelector('.validation-summary-errors') && entryDialog && goalDialog?.dataset.openGoalOnLoad !== 'true') {
            if (entryDialog.showModal) {
                entryDialog.showModal();
            } else {
                entryDialog.setAttribute('open', 'open');
            }
        }

        function parseDateOnly(value) {
            const parts = value.split('-').map(Number);
            return new Date(parts[0], parts[1] - 1, parts[2]);
        }

        function addMonths(date, months) {
            return new Date(date.getFullYear(), date.getMonth() + months, date.getDate());
        }

        function rangeStartDate(range, endDate) {
            if (range === 'all') {
                return null;
            }

            const monthsByRange = { '1m': -1, '3m': -3, '6m': -6, '1y': -12 };
            return addMonths(endDate, monthsByRange[range] || -6);
        }

        function filterPoints(points, startDate) {
            if (!startDate) {
                return points;
            }

            return points.filter((point) => parseDateOnly(point.date) >= startDate);
        }

        function buildTrendData(dailyPoints, movingPoints, goalWeight, range) {
            const endDate = parseDateOnly(today);
            const startDate = rangeStartDate(range, endDate);
            const filteredDaily = filterPoints(dailyPoints, startDate);
            const filteredMoving = filterPoints(movingPoints, startDate);
            const labels = filteredDaily.map((point) => point.date);

            return {
                labels,
                datasets: [
                    { label: 'Daily', data: filteredDaily.map((point) => point.weightKg), borderColor: '#28f0d4', backgroundColor: 'rgba(40, 240, 212, 0.12)', tension: 0.35, pointRadius: 2 },
                    { label: '7-day avg', data: filteredMoving.map((point) => point.weightKg), borderColor: '#f8c14a', tension: 0.35, pointRadius: 0 },
                    { label: 'Goal', data: goalWeight ? labels.map(() => goalWeight) : [], borderColor: '#85e89d', borderDash: [6, 6], pointRadius: 0 }
                ]
            };
        }

        function createTrendChart(canvasId, dailyPoints, movingPoints, goalWeight) {
            const canvas = document.getElementById(canvasId);
            if (!canvas || !window.Chart) {
                return null;
            }

            return new Chart(canvas, {
                type: 'line',
                data: buildTrendData(dailyPoints, movingPoints, goalWeight, '6m'),
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#7d8798', maxTicksLimit: 5 } },
                        y: { grid: { color: 'rgba(255,255,255,0.06)' }, ticks: { color: '#7d8798' } }
                    }
                }
            });
        }

        const trendDaily = @Json.Serialize(Model.LongRangeChart.DailyWeights);
        const trendMoving = @Json.Serialize(Model.LongRangeChart.MovingAverages);
        const trendGoal = @Json.Serialize(Model.LongRangeChart.GoalWeightKg);
        const trendChart = createTrendChart('trendChart', trendDaily, trendMoving, trendGoal);
        const trendRangeLabel = document.querySelector('[data-trend-range-label]');

        document.querySelectorAll('[data-trend-range]').forEach((button) => {
            button.addEventListener('click', () => {
                if (!trendChart) {
                    return;
                }

                document.querySelectorAll('[data-trend-range]').forEach((rangeButton) => {
                    rangeButton.setAttribute('aria-pressed', rangeButton === button ? 'true' : 'false');
                });

                trendChart.data = buildTrendData(trendDaily, trendMoving, trendGoal, button.dataset.trendRange);
                trendChart.update();

                if (trendRangeLabel) {
                    trendRangeLabel.textContent = button.dataset.rangeLabel;
                }
            });
        });
    </script>
}
